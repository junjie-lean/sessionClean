{
  "manifest_version": 3,
  "name": "Session Clean",
  "version": "0.3.0",
  "description": "按选项清理当前页面的会话与缓存数据",
  "permissions": [
    "cookies",
    "browsingData",
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "popup/assets/icon.png",
    "48": "popup/assets/icon.png",
    "128": "popup/assets/icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Session Clean",
    "default_icon": {
      "16": "popup/assets/icon.png",
      "32": "popup/assets/icon.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  }
}
